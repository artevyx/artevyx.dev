# Editor configuration, see https://editorconfig.org
root = true

[*]
charset = utf-8
indent_size = 2
indent_style = space
insert_final_newline = false
trim_trailing_whitespace = false
quote_type = single

[*.ts]
ij_typescript_use_double_quotes = false


[*.md]
max_line_length = off
trim_trailing_whitespace = false
